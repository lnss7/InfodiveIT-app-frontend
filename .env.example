# ============================================================
# Infodive — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env.local e preencha com seus valores.
# NUNCA commite o .env.local no Git.

# --- Payload ---
# Gere uma chave aleatória: openssl rand -hex 32
PAYLOAD_SECRET=

# --- Banco de Dados (Neon PostgreSQL) ---
# Pegue em: https://console.neon.tech/
DATABASE_URI=postgresql://user:password@host/database?sslmode=require

# --- Storage (Vercel Blob) ---
# Pegue em: Vercel Dashboard → Storage → Blob → Connect
BLOB_READ_WRITE_TOKEN=

# --- Resend (envio de e-mails para leads) ---
# Pegue em: https://resend.com/api-keys
RESEND_API_KEY=

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Integrações Sociais ---
# Configurar mais tarde via /admin → Configurações → APIs Sociais
# Os tokens ficam no banco, não aqui
